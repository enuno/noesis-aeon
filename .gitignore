# macOS
.DS_Store

# Secrets & local env
.env
.env.local
.env.*.local

# Claude Code local state
.claude/

# Caches — prefetch scripts write these, skills read them; regenerated every run
# (.xai-cache, .verdikta-cache, .treasury-cache, .star-cache, .github-releases-cache, …)
.*-cache/
.tg_cache/

# Pending queues — postprocess scripts consume + delete these after the run
# (.pending-notify, .pending-email, .pending-admanage, .pending-verdikta, …),
# plus the .pending-notify-temp scratch where skills stage notify bodies for `./notify -f`
.pending-*/

# Skill provenance lock (per-repo, not committed)
skills.lock

# Scratch / temp files
tmp_*
*.tmp
.tmp-*
.pending-*.sh
.run-*.sh
.*-tmp.md
.*-draft.md
.*-msg.txt
*_msg.txt
*_raw.txt

# Leaked creds scratch
.xai_key
.ghtoken

# Python bytecode
__pycache__/
*.pyc

# Node
node_modules/

# Stale artifacts
.external-work
.vuln-scan/
